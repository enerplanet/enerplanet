# App Configuration
APP_NAME=Enerplanet
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
APP_URL=http://localhost:8000
APP_TIMEZONE=Europe/Berlin

# Auth Service Configuration
AUTH_SERVICE_URL=http://localhost:8001

# Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_DATABASE=spatialai
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Session Configuration
SESSION_TTL_MINUTES=60
COOKIE_DOMAIN=localhost

# SMTP Configuration (for optional email sending)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=changeme
SMTP_FROM_NAME=Enerplanet
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=redis_password
REDIS_DATABASE=0

# Downstream Microservices
WEBSERVICE_SERVICE_URL=http://localhost:8089
GEOSERVER_SERVICE_URL=http://localhost:8083
PYLOVO_SERVICE_URL=http://localhost:8086

# GeoServer Direct Access (for WMS proxy)
GEOSERVER_BASE_URL=http://localhost:8180/geoserver

# Keycloak Configuration
KEYCLOAK_URL=http://localhost:8080/keycloak
KEYCLOAK_REALM=spatialhub
KEYCLOAK_CLIENT_ID=spatialhub
REDIRECT_URL=http://localhost:3000/callback-auth
# Callback authentication (shared secret for webservice callbacks)
# Generate with: openssl rand -hex 32
